# ================================================================
# 🔐 ARUME PRO - Variables de Entorno
# ================================================================
# Copia este archivo como .env y rellena los valores reales.
# ¡NUNCA subas el archivo .env a git! Ya está en el .gitignore.
# ================================================================

# 🗄️ BASE DE DATOS (Supabase)
# Encuéntralos en: https://supabase.com/dashboard → tu proyecto → Settings → API
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# 🔒 PIN DE ACCESO A LA APP (mínimo 4 dígitos, cámbialo por algo que no sea obvio)
VITE_APP_PIN=""

# 🧠 INTELIGENCIA ARTIFICIAL (Gemini)
# Esta key NO se incluye en el bundle. El usuario la introduce en Ajustes dentro de la app.
# Puedes dejarla vacía aquí; sólo es necesaria si usas el servidor backend (server.ts).
VITE_GEMINI_API_KEY=""

# 🌐 URL de la app (para self-referential links o callbacks OAuth)
APP_URL="http://localhost:5173"
